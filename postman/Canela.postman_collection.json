{
  "info": {
    "name": "Canela API",
    "description": "Coleccion para probar la API de Canela en local.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "leadId",
      "value": ""
    },
    {
      "key": "actividadId",
      "value": ""
    },
    {
      "key": "vendedorId",
      "value": "vendedor-001"
    }
  ],
  "item": [
    {
      "name": "Leads",
      "item": [
        {
          "name": "Listar leads",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/leads",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "leads"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var data = pm.response.json();",
                  "if (Array.isArray(data) && data.length > 0 && data[0].id) {",
                  "    pm.collectionVariables.set('leadId', data[0].id);",
                  "    if (data[0].vendedorId) pm.collectionVariables.set('vendedorId', data[0].vendedorId);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Crear lead",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Juan Perez\",\n  \"telefono\": \"+52 55 1111 2222\",\n  \"email\": \"juan@empresa.com\",\n  \"vendedorId\": \"{{vendedorId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/leads",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "leads"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "var data = pm.response.json();",
                  "if (data && data.id) {",
                  "    pm.collectionVariables.set('leadId', data.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Actualizar estado de lead",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"estado\": \"CONTACTADO\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/leads/{{leadId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "leads",
                "{{leadId}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Actividades",
      "item": [
        {
          "name": "Crear actividad",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tipo\": \"LLAMADA\",\n  \"descripcion\": \"Llamar para seguimiento comercial\",\n  \"fecha\": \"2026-04-02T10:00:00\",\n  \"leadId\": \"{{leadId}}\",\n  \"vendedorId\": \"{{vendedorId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/actividades",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "actividades"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "var data = pm.response.json();",
                  "if (data && data.id) {",
                  "    pm.collectionVariables.set('actividadId', data.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Listar actividades por lead",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/actividades/lead/{{leadId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "actividades",
                "lead",
                "{{leadId}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Completar actividad",
          "request": {
            "method": "PUT",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/actividades/{{actividadId}}/completar",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "actividades",
                "{{actividadId}}",
                "completar"
              ]
            }
          }
        },
        {
          "name": "Eliminar actividad",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/actividades/{{actividadId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "actividades",
                "{{actividadId}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Calendario",
      "item": [
        {
          "name": "Listar calendario",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/calendario",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "calendario"
              ]
            }
          }
        },
        {
          "name": "Calendario por vendedor",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/calendario/vendedor/{{vendedorId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "calendario",
                "vendedor",
                "{{vendedorId}}"
              ]
            }
          }
        }
      ]
    }
  ]
}
